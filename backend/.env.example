# Copy to backend/.env for local dev. All gitignored.

# Local dev defaults to a SQLite file if unset. For prod use the Supabase
# pooled connection string (Supabase -> Connect -> SQLAlchemy), e.g.
#   postgresql+psycopg2://postgres.<ref>:<pw>@<host>:6543/postgres
DATABASE_URL=sqlite:///./elp_dev.db

# Allowed browser origins (comma-separated). Add your deployed frontend URL in prod.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Supabase project URL (https://<ref>.supabase.co). Used to verify asymmetric
# (ES256/RS256) access tokens via the project's JWKS endpoint — how current
# Supabase projects sign tokens. Required for the /me/* routes.
SUPABASE_URL=

# Legacy shared JWT secret (Settings -> JWT Keys -> Legacy JWT Secret). Only
# needed for older projects that still sign with HS256. Optional otherwise.
SUPABASE_JWT_SECRET=
