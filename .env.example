# Optional: unavatar Pro API key, enables real Instagram/Twitter profile photos
# on the "My Local Business" cards. Get one at https://unavatar.io/checkout
# Copy this file to `.env` and paste your key. Restart the dev server after.
VITE_UNAVATAR_KEY=

# Supabase (real auth + per-user data). From the dashboard's Connect dialog
# (Framework: React, Variant: Vite). Both are safe to expose in the browser;
# RLS protects your data. The "publishable" key is Supabase's newer name for
# the old "anon" key.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# ELP backend (the FastAPI service). Leave blank to keep saved events and
# followed businesses in the browser only (localStorage). Set it to turn on
# per-account server sync:
#   dev:  http://127.0.0.1:8000
#   prod: https://elp-api.onrender.com
VITE_API_BASE=
