# Optional: unavatar Pro API key, enables real Instagram/Twitter profile photos
# on the "My Local Business" cards. Get one at https://unavatar.io/checkout
# Copy this file to `.env` and paste your key. Restart the dev server after.
VITE_UNAVATAR_KEY=

# Supabase (real auth + per-user data). From Project Settings -> API.
# Both are safe to expose in the browser; RLS protects your data.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
