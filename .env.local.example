# Cloudflare Pages deploy credentials. Copy to `.env.local` (gitignored) and
# fill in. wrangler reads these from the environment, so before deploying:
#
#   set -a; source .env.local; set +a   # export them into your shell
#   npm run deploy
#
# Or skip this file entirely and run `wrangler login` once (browser OAuth).

# Cloudflare API token — create at https://dash.cloudflare.com/profile/api-tokens
# Permissions: "Cloudflare Pages: Edit" + "Account Settings: Read".
CLOUDFLARE_API_TOKEN=

# Your Cloudflare account ID (dashboard sidebar / any zone's Overview page).
CLOUDFLARE_ACCOUNT_ID=
